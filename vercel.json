{
  "framework": "vite",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build",
  "rewrites": [
    { "source": "/api/oauth/line/start", "destination": "/api/trpc/line-oauth-start" },
    { "source": "/api/oauth/line/callback", "destination": "/api/trpc/line-oauth-callback" },
    { "source": "/api/oauth-line-start", "destination": "/api/trpc/line-oauth-start" },
    { "source": "/api/oauth-line-callback", "destination": "/api/trpc/line-oauth-callback" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
